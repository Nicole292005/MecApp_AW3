<div class="contenedor-formulario">
    <h2>Crear Producto</h2>

    {{#if errores}}
        <div class="alerta-error">
            {{#each errores}}
                <p>{{msg}}</p>
            {{/each}}
        </div>
    {{/if}}

    <form action="/productos/crear" method="POST" enctype="multipart/form-data">
        <div class="grupo-campo">
            <label for="nombre">Nombre del producto</label>
            <input type="text" id="nombre" name="nombre" value="{{nombre}}" placeholder="Nombre del producto" required>
        </div>

        <div class="grupo-campo">
            <label for="precio">Precio</label>
            <input type="number" id="precio" name="precio" value="{{precio}}" placeholder="0.00" step="0.01" min="0" required>
        </div>

        <div class="grupo-campo">
            <label for="descripcion">Descripción</label>
            <textarea id="descripcion" name="descripcion" placeholder="Descripción del producto" rows="4">{{descripcion}}</textarea>
        </div>

        <div class="grupo-campo">
            <label for="imagen">Imagen del producto</label>
            <input type="file" id="imagen" name="imagen" accept="image/jpeg,image/png">
            <small class="texto-ayuda">Formatos permitidos: JPG, PNG. Tamaño máximo: 5MB.</small>
        </div>

        <div class="grupo-botones">
            <button type="submit" class="boton boton-principal">Guardar producto</button>
            <a href="/productos" class="boton boton-secundario">Cancelar</a>
        </div>
    </form>
</div>

<div class="contenedor-formulario">
    <h2>Editar Producto</h2>

    {{#if errores}}
        <div class="alerta-error">
            {{#each errores}}
                <p>{{msg}}</p>
            {{/each}}
        </div>
    {{/if}}

    <form action="/productos/editar/{{producto._id}}" method="POST" enctype="multipart/form-data">
        <div class="grupo-campo">
            <label for="nombre">Nombre del producto</label>
            <input type="text" id="nombre" name="nombre" value="{{producto.nombre}}" required>
        </div>

        <div class="grupo-campo">
            <label for="precio">Precio</label>
            <input type="number" id="precio" name="precio" value="{{producto.precio}}" step="0.01" min="0" required>
        </div>

        <div class="grupo-campo">
            <label for="descripcion">Descripción</label>
            <textarea id="descripcion" name="descripcion" rows="4">{{producto.descripcion}}</textarea>
        </div>

        <div class="grupo-campo">
            {{#if producto.imagen}}
                <p class="etiqueta-imagen">Imagen actual:</p>
                <img src="/uploads/{{producto.imagen}}" alt="{{producto.nombre}}" class="imagen-preview">
            {{/if}}
            <label for="imagen">{{#if producto.imagen}}Cambiar imagen{{else}}Imagen del producto{{/if}}</label>
            <input type="file" id="imagen" name="imagen" accept="image/jpeg,image/png">
            <small class="texto-ayuda">Formatos permitidos: JPG, PNG. Tamaño máximo: 5MB. Deja vacío para mantener la imagen actual.</small>
        </div>

        <div class="grupo-botones">
            <button type="submit" class="boton boton-principal">Guardar cambios</button>
            <a href="/productos" class="boton boton-secundario">Cancelar</a>
        </div>
    </form>
</div>
